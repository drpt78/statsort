# test/Jamfile.v2
#
# Boost.Algorithm.Statsort — test suite
# Build with:  b2  (from the repository root)
#
# Copyright (c) Peter Taraba 2025
# Distributed under the Boost Software License, Version 1.0.

import testing ;

project statsort/test
    : requirements
        <include>../include
        <cxxstd>17
    ;

# ── unit-test binary ──────────────────────────────────────────────────────────
#
# All test cases are compiled into a single binary.  Add new .cpp files here
# as the test suite grows.

run statsort_test.cpp
    : # args
    : # input files
    : # requirements
      <library>/boost/test//boost_unit_test_framework
    : statsort_test                    # target name / binary name
    ;
